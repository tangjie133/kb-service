# GitHub Configuration (方式 A: 使用 GitHub 仓库)
# 格式: username/repo-name
GITHUB_REPO=
GITHUB_TOKEN=
SYNC_INTERVAL=300

# Local Knowledge Path (方式 B: 使用本地文件夹)
# 如果设置，优先使用本地路径而不是 GitHub
LOCAL_KNOWLEDGE_PATH=./knowledge

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
LLM_MODEL=qwen2.5

# Vector Database
VECTOR_DB_PATH=./data/vector_db
COLLECTION_NAME=knowledge

# Text Processing
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Search
TOP_K=5
SIMILARITY_THRESHOLD=0.7
